# Copy this to .env and fill in your values
# NEVER commit .env to Git

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creditlens
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-256-bit-secret

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# Leave blank to use the deterministic template fallback (no API cost)
# Set to your key for full GPT-4 explanations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ── Risk thresholds (optional — defaults shown) ───────────────────────────────
MAX_FOIR=0.60
MAX_LTV=0.80
MAX_DTI=0.55
MIN_CREDIT_SCORE=650
MIN_AGE=21
MAX_AGE=65
